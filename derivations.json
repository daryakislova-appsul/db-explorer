    "ad_impressions_interstitial": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(ad_impressions_interstitial)", "aggregation": "SUM"},
    "ad_impressions_banner": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(ad_impressions_banner)", "aggregation": "SUM"},
    "inapp_revenue_gross": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(inapp_revenue_gross)", "aggregation": "SUM"},
    "subs_revenue_gross": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(subs_revenue_gross)", "aggregation": "SUM"},
    "ad_revenue_gross": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(ad_revenue_gross)", "aggregation": "SUM"},
    "inapp_refunds_revenue_net": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(inapp_refunds_revenue_net)", "aggregation": "SUM"},
    "subs_refunds_revenue_net": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(subs_refunds_revenue_net)", "aggregation": "SUM"},
    "inapp_revenue_net": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(inapp_revenue_net)", "aggregation": "SUM"},
    "subs_revenue_net": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(subs_revenue_net)", "aggregation": "SUM"},
