    "subscription_purchases": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(subscription_purchases)", "aggregation": "SUM"},
    "subscription_refunds_num": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(subscription_refunds_num)", "aggregation": "SUM"},
    "trial_purchases": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(trial_purchases)", "aggregation": "SUM"},
    "trial_converted_purchases": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(trial_converted_purchases)", "aggregation": "SUM"},
    "renewal_purchases": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(renewal_purchases)", "aggregation": "SUM"},
    "cancelations": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(cancelations)", "aggregation": "SUM"},
    "ad_impressions": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "sum(ad_impressions)", "aggregation": "SUM"},
