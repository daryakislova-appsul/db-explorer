{
  "gold.ua_user_lifetime_activity_daily": {
    "_model": "gold__ua_user_lifetime_activity_daily.sql",
    "_sources": ["silver__user_activity_daily", "silver__inapp_table", "silver__subscription_table", "silver__applovin_ad_user_daily", "silver__users_scd2"],
    "_join_strategy": "4 CTEs (activity/inapp/subscription/ad_revenue) are enriched via LEFT ASOF JOIN on silver.users_scd2 (install_time <= event_time), then UNION ALL and re-aggregated. Final INNER JOIN back to user_lifetimes for dimension columns.",
    "cohort_date": {"source": "silver.users_scd2", "formula": "toDate(install_time)", "via_cte": "user_lifetimes"},
    "cohort_month": {"source": "silver.users_scd2", "formula": "toStartOfMonth(toDate(install_time))", "via_cte": "user_lifetimes"},
    "cohort_week": {"source": "silver.users_scd2", "formula": "toStartOfWeek(toDate(install_time), 5)", "via_cte": "user_lifetimes"},
    "event_date": {"source": "silver.user_activity_daily / silver.inapp_table / silver.subscription_table / silver.applovin_ad_user_daily", "formula": "activity_date_utc or toDate(event_time) or event_date depending on CTE", "via_cte": "aggregated"},
    "day_idx": {"source": "computed", "formula": "toUInt16(dateDiff('day', cohort_date, event_date))", "via_cte": "final SELECT"},
    "platform": {"source": "silver.users_scd2", "formula": "multiIf(platform LIKE '%ios%', 'ios', platform LIKE '%and%', 'android', 'unknown')", "via_cte": "user_lifetimes"},
    "application": {"source": "silver.users_scd2", "formula": "coalesce(nullIf(app_name, ''), 'unknown')", "via_cte": "user_lifetimes"},
    "country": {"source": "silver.users_scd2", "formula": "coalesce(country_code, '')", "via_cte": "user_lifetimes"},
    "media_source": {"source": "silver.users_scd2", "formula": "coalesce(media_source, '')", "via_cte": "user_lifetimes"},
    "promo_campaign": {"source": "silver.users_scd2", "formula": "coalesce(promo_campaign, '')", "via_cte": "user_lifetimes"},
    "promo_campaign_id": {"source": "silver.users_scd2", "formula": "coalesce(promo_campaign_id, '')", "via_cte": "user_lifetimes"},
    "ad": {"source": "silver.users_scd2", "formula": "coalesce(ad, '')", "via_cte": "user_lifetimes"},
    "adset": {"source": "silver.users_scd2", "formula": "coalesce(adset, '')", "via_cte": "user_lifetimes"},
    "install_device_name": {"source": "silver.users_scd2", "formula": "coalesce(install_device_name, '')", "via_cte": "user_lifetimes"},
    "install_device_type": {"source": "silver.users_scd2", "formula": "coalesce(install_device_type, '')", "via_cte": "user_lifetimes"},
    "client_id": {"source": "silver.users_scd2", "formula": "pass-through", "via_cte": "user_lifetimes"},
    "user_lifetime_id": {"source": "silver.users_scd2", "formula": "pass-through", "via_cte": "user_lifetimes"},
    "user_lifetime_number": {"source": "silver.users_scd2", "formula": "pass-through", "via_cte": "user_lifetimes"},
    "install_time": {"source": "silver.users_scd2", "formula": "pass-through", "via_cte": "user_lifetimes"},
    "lifetime_start_date": {"source": "silver.users_scd2", "formula": "toDate(install_time)", "via_cte": "user_lifetimes"},
    "lifetime_end_date": {"source": "silver.users_scd2", "formula": "if(isNull(lifetime_end_time), NULL, toDate(lifetime_end_time))", "via_cte": "user_lifetimes"},
    "sessions_count": {"source": "silver.user_activity_daily", "formula": "sum(sessions_count)", "via_cte": "activity_daily -> aggregated", "aggregation": "SUM across UNION ALL of 4 CTEs, GROUP BY (event_date, application, client_id, user_lifetime_id)"},
    "session_duration_seconds_total": {"source": "silver.user_activity_daily", "formula": "sum(session_duration_seconds_total)", "via_cte": "activity_daily -> aggregated", "aggregation": "SUM"},
    "session_event_count_total": {"source": "silver.user_activity_daily", "formula": "sum(session_event_count_total)", "via_cte": "activity_daily -> aggregated", "aggregation": "SUM"},
    "app_version_last": {"source": "silver.user_activity_daily", "formula": "argMax(app_version_last, app_version_priority)", "via_cte": "activity_daily -> aggregated", "aggregation": "argMax (picks activity CTE value over others)"},
    "purchases": {"source": "silver.inapp_table + silver.subscription_table", "formula": "sum(countIf(event_name='purchase')) from inapp + countIf(event_name='purchase' AND period_type='normal') from subs", "via_cte": "inapp_daily + subscription_daily -> aggregated", "aggregation": "SUM"},
    "refunds": {"source": "silver.inapp_table + silver.subscription_table", "formula": "sum(countIf(event_name='refund'))", "via_cte": "inapp_daily + subscription_daily -> aggregated", "aggregation": "SUM"},
    "inapp_purchases": {"source": "silver.inapp_table", "formula": "countIf(event_name='purchase')", "via_cte": "inapp_daily -> aggregated", "aggregation": "SUM"},
    "inapp_refunds_num": {"source": "silver.inapp_table", "formula": "countIf(event_name='refund')", "via_cte": "inapp_daily -> aggregated", "aggregation": "SUM"},
    "subscription_purchases": {"source": "silver.subscription_table", "formula": "countIf(event_name='purchase' AND period_type='normal')", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "subscription_refunds_num": {"source": "silver.subscription_table", "formula": "countIf(event_name='refund')", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "trial_purchases": {"source": "silver.subscription_table", "formula": "countIf(event_name='purchase' AND period_type LIKE '%trial%')", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "trial_converted_purchases": {"source": "silver.subscription_table", "formula": "countIf(event_name='purchase' AND is_trial_conversion=1)", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "renewal_purchases": {"source": "silver.subscription_table", "formula": "countIf(event_name='purchase' AND type='RENEWAL')", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "cancelations": {"source": "silver.subscription_table", "formula": "countIf(cancel_ind=1)", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "ad_impressions": {"source": "silver.applovin_ad_user_daily", "formula": "sum(impressions_count)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "ad_impressions_rewarded": {"source": "silver.applovin_ad_user_daily", "formula": "sum(impressions_rewarded)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "ad_impressions_interstitial": {"source": "silver.applovin_ad_user_daily", "formula": "sum(impressions_interstitial)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "ad_impressions_banner": {"source": "silver.applovin_ad_user_daily", "formula": "sum(impressions_banner)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "inapp_revenue_gross": {"source": "silver.inapp_table", "formula": "sumIf(abs(price_gross), event_name='purchase')", "via_cte": "inapp_daily -> aggregated", "aggregation": "SUM. Price is net USD from silver.inapp_table (already converted via calc_price_usd macro)"},
    "subs_revenue_gross": {"source": "silver.subscription_table", "formula": "sumIf(abs(price_gross), event_name='purchase' AND period_type='normal')", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "ad_revenue_gross": {"source": "silver.applovin_ad_user_daily", "formula": "sum(ad_revenue_total)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "inapp_refunds_revenue_net": {"source": "silver.inapp_table", "formula": "sumIf(abs(price), event_name='refund')", "via_cte": "inapp_daily -> aggregated", "aggregation": "SUM"},
    "subs_refunds_revenue_net": {"source": "silver.subscription_table", "formula": "sumIf(abs(price), event_name='refund')", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM"},
    "inapp_revenue_net": {"source": "silver.inapp_table", "formula": "sumIf(if(event_name='purchase', 1, -1) * abs(price), event_name IN ('purchase','refund'))", "via_cte": "inapp_daily -> aggregated", "aggregation": "SUM. Purchases positive, refunds negative."},
    "subs_revenue_net": {"source": "silver.subscription_table", "formula": "sumIf(if(event_name='purchase', 1, -1) * abs(price), (event_name='purchase' AND period_type='normal') OR event_name='refund')", "via_cte": "subscription_daily -> aggregated", "aggregation": "SUM. Only normal-period purchases count, refunds subtract."},
    "ad_revenue_rewarded_gross": {"source": "silver.applovin_ad_user_daily", "formula": "sum(revenue_rewarded)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "ad_revenue_interstitial_gross": {"source": "silver.applovin_ad_user_daily", "formula": "sum(revenue_interstitial)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "ad_revenue_banner_gross": {"source": "silver.applovin_ad_user_daily", "formula": "sum(revenue_banner)", "via_cte": "ad_revenue_daily -> aggregated", "aggregation": "SUM"},
    "total_revenue_gross": {"source": "computed", "formula": "inapp_revenue_gross + subs_revenue_gross + ad_revenue_gross", "via_cte": "final SELECT"},
    "total_revenue_net": {"source": "computed", "formula": "inapp_revenue_net + subs_revenue_net + ad_revenue_gross", "via_cte": "final SELECT", "aggregation": "Note: uses ad_revenue_GROSS (no net concept for ads)"},
    "version": {"source": "system", "formula": "now()", "via_cte": "final SELECT"}
  },

