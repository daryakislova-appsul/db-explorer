  "gold.ua_payers": {
    "_model": "gold__ua_payers.sql",
    "_sources": ["gold__ua_cohort_users", "silver__inapp_table", "silver__subscription_table"],
    "_join_strategy": "UNION ALL of inapp purchases (event_name='purchase') and subscription purchases, then INNER JOIN to gold.ua_cohort_users to pin purchases to correct user lifetime window (event_date >= lifetime_start_date AND < lifetime_end_date). Aggregated per user lifetime.",
    "cohort_date": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "cohort_month": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "cohort_week": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "platform": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "application": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "country": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "media_source": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "promo_campaign": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "promo_campaign_id": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "ad": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "adset": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "client_id": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "user_lifetime_id": {"source": "gold.ua_cohort_users", "formula": "pass-through"},
    "is_inapp_payer": {"source": "silver.inapp_table", "formula": "toUInt8(inapp_purchases > 0)", "aggregation": "Flag derived from count"},
    "is_subscription_payer": {"source": "silver.subscription_table", "formula": "toUInt8(subscription_purchases > 0)", "aggregation": "Flag derived from count"},
    "purchases_total": {"source": "silver.inapp_table + silver.subscription_table", "formula": "count()", "aggregation": "COUNT of all purchases in lifetime window"},
    "inapp_purchases": {"source": "silver.inapp_table", "formula": "countIf(purchase_type='inapp')", "aggregation": "COUNT"},
    "subscription_purchases": {"source": "silver.subscription_table", "formula": "countIf(purchase_type='subscription')", "aggregation": "COUNT"},
    "inapp_currency": {"source": "silver.inapp_table", "formula": "if(countDistinct(currency)=1, any(currency), 'MULTI')"},
    "subscription_currency": {"source": "silver.subscription_table", "formula": "if(countDistinct(currency)=1, any(currency), 'MULTI')"},
    "inapp_amount_local_total": {"source": "silver.inapp_table", "formula": "if(single_currency, sumIf(local_amount, inapp), NULL)"},
    "subscription_amount_local_total": {"source": "silver.subscription_table", "formula": "if(single_currency, sumIf(local_amount, subscription), NULL)"},
    "inapp_amount_usd_total": {"source": "silver.inapp_table", "formula": "sumIf(amount_usd, purchase_type='inapp')", "aggregation": "SUM in USD"},
    "subscription_amount_usd_total": {"source": "silver.subscription_table", "formula": "sumIf(amount_usd, purchase_type='subscription')", "aggregation": "SUM in USD"},
    "first_purchase_timestamp": {"source": "silver.inapp_table + silver.subscription_table", "formula": "min(purchase_time)", "aggregation": "MIN across all purchase types"},
    "first_purchase_date": {"source": "computed", "formula": "toDate(min(purchase_time))"},
    "first_inapp_purchase_date": {"source": "silver.inapp_table", "formula": "minIf(event_date, purchase_type='inapp')"},
    "first_subscription_purchase_date": {"source": "silver.subscription_table", "formula": "minIf(event_date, purchase_type='subscription')"},
    "version": {"source": "system", "formula": "now()"}
  },

  "gold.ua_cohort_long": {
