    "day_idx": {"source": "gold.ua_user_lifetime_activity_daily", "formula": "pass-through (0 for install/cost branches)"},
    "platform": {"source": "pass-through", "formula": "pass-through"},
    "application": {"source": "pass-through", "formula": "pass-through"},
    "country": {"source": "pass-through", "formula": "pass-through"},
    "media_source": {"source": "pass-through", "formula": "pass-through"},
    "promo_campaign": {"source": "pass-through", "formula": "pass-through"},
